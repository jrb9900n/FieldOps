{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "cleanUrls": false,
  "rewrites": [
    { "source": "/expense-consent", "destination": "/index.html" },
    { "source": "/privacy-policy",  "destination": "/index.html" },
    { "source": "/expense/(.*)",    "destination": "/index.html" }
  ]
}
